# ============================================================
#  Job Bot — Environment Variables
#  Copy to .env and fill in your values
# ============================================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=your_chat_id_here   # Get via @userinfobot

# --- LinkedIn (optional — use cookies for scraping) ---
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword
# Or paste cookie string from browser DevTools → Application → Cookies
LINKEDIN_COOKIE=

# --- Xing ---
XING_EMAIL=your@email.com
XING_PASSWORD=yourpassword

# --- Search Keywords (comma-separated) ---
SEARCH_KEYWORDS=Python Developer,Backend Engineer,Data Engineer,Software Engineer
SEARCH_LOCATIONS=Munich,Berlin,Remote,Frankfurt
SEARCH_LANGUAGE=en    # en or de

# --- Job Filtering ---
MIN_RELEVANCE_SCORE=6   # Only notify for jobs scoring >= this (1-10)
MAX_JOBS_PER_SCAN=20    # Max new jobs to surface per scan cycle

# --- Scheduling ---
SCAN_INTERVAL_HOURS=4   # How often to auto-scan (0 = manual only)

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-to-a-random-string   # Used to authenticate webhook calls

# --- Paths ---
CV_TEMPLATE_PATH=templates/base/CV.docx
CL_TEMPLATE_PATH=templates/base/CL.docx
OUTPUT_DIR=data/applications
TRACKING_EXCEL=data/job_tracker.xlsx
DATABASE_URL=sqlite+aiosync:///data/jobs.db

# --- CV Colored Sections ---
# Which color marks replaceable sections in your CV/CL template
# Options: YELLOW, CYAN, GREEN, PINK, RED, BLUE, TURQUOISE
CV_HIGHLIGHT_COLOR=YELLOW
